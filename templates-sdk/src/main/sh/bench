### Page width warning: output_width_warning()
# Prints a warning message when the page width is below 150,
#   the minimum width that this script is designed to support.
#   The warning message displays the detected page width and
#   the minimum and expected page widths.
#
## Sets: nothing.
#
## v1.0.0
output_width_warning() {
  if [[ "$page_width" -le 160 ]]; then
    print "\n\nWARNING: Data obstructed!\n  Your page width is $page_width.\n  Page width below 160 is not supported.\n  180 is the minimum designed width.\n  200 is recommended width.\n\n"
  fi
}

### Print flags used to run the script: print_flags()
# Prints a table of flags used to run the script, including:
# - tests run (IO, CPU, Memory);
# - debug options (dry_run);
# - information about the platform (is_macos_local, is_linux_agent).
#
## Sets: nothing.
#
## v1.0.0
print_flags(){

  local -ir enabled_tests_max_length=26 run_os_max_length=19

  local -i enabled_tests_length run_os_config_length agent_machine_length=${#agent_machine}
  local enabled_tests="Tests:"
  local run_os_config="OS:"

  [[ "$exec_fio_bench" == true ]] && enabled_tests+=" file-IO"
  [[ "$exec_cpu_bench" == true ]] && enabled_tests+=" CPU"
  [[ "$exec_mem_bench" == true ]] && enabled_tests+=" Memory"                                       # Max length 26
  [[ "$dry_run" == true ]] && run_os_config+=" (dry-run)"
  [[ "$is_macos_local" == true ]] && run_os_config+=" UNIX"
  [[ "$is_linux_agent" == true ]] && run_os_config+=" Linux"
  enabled_tests_length=${#enabled_tests}
  run_os_config_length=${#run_os_config}
  readonly enabled_tests_length run_os_config_length enabled_tests run_os_config agent_machine_length

  local -i minimum_data_length desired_data_length
  (( minimum_data_length = 2 * margin_length + divider_length + enabled_tests_length + run_os_config_length ))
  (( minimum_kernel_print_length = 2 * margin_length + agent_machine_length ))
  (( desired_data_length = 2 * margin_length + 2 * divider_length + enabled_tests_length + run_os_config_length  + agent_machine_length))
  [[ $minimum_kernel_print_length -gt $minimum_data_length ]] && minimum_data_length=$minimum_kernel_print_length
  readonly minimum_data_length desired_data_length minimum_kernel_print_length

  print "$bar_h2"
  if (( page_width >= desired_data_length )); then
    (( remaining_length = page_width - 2 * margin_length - 2 * divider_length - enabled_tests_length - run_os_config_length ))
    printf "$divider %-${enabled_tests_length}s $divider %-${run_os_config_length}s $divider %${remaining_length}s $divider\n" \
      "$enabled_tests" "$run_os_config" "$agent_machine"
  elif (( page_width >= minimum_data_length )); then
    (( remaining_length = page_width - 2 * margin_length - divider_length - enabled_tests_length ))
    (( single_remaining_length = page_width - 2 * margin_length ))
    printf "$divider %-${enabled_tests_length}s $divider %${remaining_length}s $divider\n" "$enabled_tests" "$run_os_config"
    printf "$divider %${single_remaining_length}s $divider\n" "$agent_machine"
  else
    print "\n$enabled_tests\n"
  fi
  print "$bar_h2"
}

### Print file system resources ALWAYS used: print_filesystem_resources_used()
#
# This function prints the file system resources used during the benchmark
# tests to standard output. It formats each resource path as a URI and
# displays them with descriptive labels. The resources include:
# - Root Resource
# - Work Resource
# - Test Resource
# - Bench Results
# - Bench Components
# - Bench Summary
#
# Each resource path is printed in a uniform format for better readability.
#
## Sets: nothing.
#
## v1.0.0
print_filesystem_resources_used(){

  local -ri header_column_length=8 file_prefix_length=7
  (( data_column_length = page_width - 2 * margin_length - divider_length - header_column_length ))
  local -r fmt_rez_row="$divider %-${header_column_length}s:  %-${data_column_length}.${data_column_length}s $divider\n"

  local required_page_width=0
  # shellcheck disable=SC1036,SC1056
  foreach i ( \
    "${#run_root_resource}" \
    "${#run_work_resource}" \
    "${#run_test_resource}" \
    "${#run_bench_results_path}" \
    "${#run_bench_results_components_path}" \
    "${#run_bench_summary_file}" ) \
    { [[ "$i" -gt "$required_page_width" ]] && required_page_width=$i }
    (( required_page_width  += 2 * margin_length + divider_length + header_column_length + file_prefix_length ))

  # Place informative separators at the start of the output
  local -r bar_description='Locked FS Resources'
  local -i bar_title_margin_length bar_description_length=${#bar_description}
  (( bar_title_margin_length = page_width - title_margin_length - 2 * 2 - bar_description_length ))
  readonly bar_title_margin_length bar_description_length

  local -r fmt_bar_with_description="%1\$-${bar_title_margin_length}.${bar_title_margin_length}s   %2\$${bar_description_length}.${bar_description_length}s %1\$${title_margin_length}.${title_margin_length}s\n"
  printf "$fmt_bar_with_description" "$bar_h3" "$bar_description"


  [[ "$page_width" -eq "$required_page_width" ]] && printf "$fmt_rez_row" "WARNING"   "Maximum page width reached at $page_width chars."
  [[ "$page_width" -lt "$required_page_width" ]] && printf "$fmt_rez_row" "ERROR"     "!!TRUNCATION DETECTED!! Need $required_page_width chars; only have $page_width."

  printf "$fmt_rez_row" "Root"    "file://${run_root_resource}"
  printf "$fmt_rez_row" "Work"    "file://${run_work_resource}"
  printf "$fmt_rez_row" "Test"    "file://${run_test_resource}"
  printf "$fmt_rez_row" "Data"    "file://${run_bench_results_path}"
  printf "$fmt_rez_row" "Parts"   "file://${run_bench_results_components_path}"
  printf "$fmt_rez_row" "Summary" "file://${run_bench_summary_file}"
}

