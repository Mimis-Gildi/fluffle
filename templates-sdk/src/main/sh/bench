  local -r title_new_rez_row='Created shard' title_reused_rez_row='Reused shard'
  local -i title_length=13 local_file_separator_w_spaces_length=6 available_data_column_length
  (( available_data_column_length = page_width - local_file_separator_w_spaces_length - 2 * margin_length - title_length ))
  readonly title_length available_data_column_length
  local -r fmt_rez_row="$divider %-${title_length}.${title_length}s %4.4s %-${available_data_column_length}.${available_data_column_length}s $divider\n"

  for test_mode in "${(@k)test_modes_io_data}"; do
    for io_mode in "${(@k)test_modes_io_channels_selected}"; do
      # Establish data and log files for this component test shard
      local component_file="${run_bench_results_components_path}/${bench_agent_host_key}-${test_mode}-${io_mode}.data"
      local component_setup_file="${run_bench_results_components_path}/${bench_agent_host_key}-${test_mode}-${io_mode}.setup.log"
      local component_file_message="file://${component_file}"

      # Deal with the page width
      local -i component_file_message_length="${#component_file_message}"
      (( component_file_message_length > available_data_column_length )) && component_file_message="ERROR: Truncated; need column width of $component_file_message_length but have $available_data_column_length: increase page_width (currently $page_width)"


      # Switch visual representation based on whether or not the component needed to be generated
      local selected_file_operation="$title_reused_rez_row"
      local selected_file_operation_symbol='<-->'
      if [[ ! -f "${component_file}" ||  "$force_regenerate_fio_test_files" == true ]]; then
        pushd "${test_modes_io_data_dir_selected}" || exit 17
        sysbench fileio --file-test-mode="$test_mode" --file-io-mode="$io_mode" --file-num=$test_file_count --file-total-size="${test_io_size}" --file-rw-ratio=$test_rw_ratio prepare &> "${component_setup_file}"
        sysbench --threads=1 fileio --file-test-mode="$test_mode" --file-io-mode="$io_mode" --file-num=$test_file_count --file-total-size="${test_io_size}" --file-rw-ratio=$test_rw_ratio run &> "${component_file}"
        popd || exit 19
        selected_file_operation="$title_new_rez_row"
        selected_file_operation_symbol='|==>'
      fi

      printf "$fmt_rez_row" "${selected_file_operation}" "${selected_file_operation_symbol}" "${component_file_message}"
    done
  done
}

### Print Test Header Bar for File IO Tests: file_io_print_test_header_bar()
#
# This function prints a decorative title bar for the File IO test summary.
# It outputs a formatted header line that includes a left bar, a centered test title,
# and a right bar, all enclosed by divider characters.
#
# The function uses several global formatting variables:
#   - **page_width**:                 The total width (in characters) of the output;
#   - **title_margin_length**:        The fixed length of the left or right indentation of the title bar, i.e., '==================' ;
#   - **margin_length**:              The fixed left margin width for the left and right margins of title bars ('| ' and ' |', note that spaces are not used);
#   - **divider**:                    A string used as a column divider and a left and right bar terminator character ('|');
#   - **bar_h1**:                     A decorative bar string repeated throughout the title bar and is generate with fixed length of 'page_width', thus needs to be trimmed;
#                                     Note that 'bar_h1' is '=', 'bar_h2' is '~', and 'bar_h3' is '.';
#   - **run_bench_summary_file**:     File path where the header line is appended to build entire test summary.
#
# The header bar displays the fixed test title "💾 File IO Tests". It calculates the length of the right bar based on:
#   - The global page width,
#   - The left margin (title_margin_length),
#   - The length of the test title,
#   - Two times the margin_length (for additional spacing),
#   - An extra subtraction of 2 (to account for front-loaded 2 additional spaces before the title),
#   - And a final subtraction of 1 to account for the Unicode character width.
#
# The final formatted header line is printed using a printf format string that interpolates the left bar, test title, and right bar within divider characters.
# The output is both displayed on standard output and appended to the file specified by ${run_bench_summary_file}.
#
## Sets: nothing.
## Data Writen: nothing.
## Generates: nothing.
## Prints: Test Header Bar.
#
## v1.0.0
file_io_print_test_header_bar() {
  local -r test_title="💾 File IO Tests"
  local -ir test_title_length=${#test_title}

  # Calculate left and right bar lengths as the left one is specified by the global formatting variable 'title_margin_length'
  # Explaining calculations:
  # - margin_length accommodates an extra space (length 2 while margin is a single pipe),
  #   so, spaces around the title are covered;
  # - the next (-2) is because there are 3 spaces, not 1 before the title in the bar and 1 after, as calculated before;
  # - the last (-1) is to account for the unicode character used in the title string of the title.
  local -ir right_bar_length=$(( page_width - title_margin_length - test_title_length - 2 * margin_length - 2 - 1 ))
  printf "$divider%1\$-${title_margin_length}.${title_margin_length}s   %2\$-${test_title_length}.${test_title_length}s %1\$${right_bar_length}.${right_bar_length}s$divider\n" "$bar_h1" "$test_title" | tee -a "${run_bench_summary_file}"
}

