### Run File IO Tests
#
# This function runs sysbench File IO tests.
#
# The following tests are performed:
#   - `rndrd` (read-only): 100% reads
#   - `rndwr` (write-only): 100% writes
#   - `rndrw` (read-write): 50% reads, 50% writes
#
# The results are written to a log file.
#
# The function prints a header block of test results information to the benchmark summary file, which includes:
#   - A header label "Test Results"
#   - A horizontal line for visual separation
#
# The function also prints a footer block of test results information to the benchmark summary file, which includes:
#   - A horizontal line for visual separation
run_file_io_tests() {

  # Check if run is possible
  if [[ ! -d "$run_test_resource" ]]; then
    print "ERROR: Test Path ${run_test_resource} does not exist. Exiting."
    exit 2
  fi

  # Run File IO Tests Preparations and Calculations
  file_io_calculate_available_io_modes
  file_io_generate_test_data_directory
  file_io_generate_component_test_shards

  # Run File IO Tests Results Calculations and Printing
  file_io_print_test_header_bar
  file_io_print_results_header

}

calibrate_cpu_test_modes(){
  local -ri reported_core_count=$( getconf _NPROCESSORS_ONLN )
  local -ri detected_core_count=$test_core_count
  local -i using_core_count iterations=3

  if [[ "$reported_core_count" != "$detected_core_count" ]]; then
    print "[warning]: Reported core count does not match detected core count. Reported=$reported_core_count Detected=$detected_core_count; Using Detected Core Count of $detected_core_count."
    using_core_count=$detected_core_count
  else
    using_core_count=$reported_core_count
  fi

  [[ $using_core_count -lt 8 ]] && iterations=2
  [[ $using_core_count -gt 12 ]] && iterations=5

  local -A cpu_modes

  if [[ "$using_core_count" -lt 1 ]]; then
    print "[warning]: Detected core count is less than 1. Using 1 core."
    using_core_count=1
    cpu_modes=( ['Undetected']=1 )
  elif [[ "$using_core_count" -eq 1 ]]; then
    cpu_modes=( ['Cores']=1 ['HT']=2 ['Load']=3 )
  elif [[ "$using_core_count" -eq 2 ]]; then
    cpu_modes=( ['Single']=1 ['Cores']=2 ['HT']=4 ['Load']=8 )
  elif [[ "$using_core_count" -eq 3 ]]; then
    cpu_modes=( ['Single']=1 ['Double']=2 ['Cores']=3 ['HT']=6 ['Load']=12)
  elif [[ "$using_core_count" -eq 4 ]]; then
    cpu_modes=( ['Single']=1 ['Double']=2 ['Cores']=4 ['HT']=8 ['Load']=16 )
  elif [[ "$using_core_count" -gt 4 ]]; then
    cpu_modes=( ['Single']=1 ['Double']=2 ['Quad']=4 ['Cores']=$using_core_count ['HT']=$(( using_core_count * 2)) ['Load']=$(( using_core_count * 3 )) )
  else
    cpu_modes=( ['Undetected']=0 )
    print "[warning]: Detected core count is less than 1. Using 0 pairs."
  fi

  {
    [[ "$reported_core_count" -gt 0 ]] && printf "$format_i_data_param" "$compute_key.calibration.cores.reported" "$reported_core_count"
    [[ "$detected_core_count" -gt 0 ]] && printf "$format_i_data_param" "$compute_key.calibration.cores.detected" "$detected_core_count"
    [[ "$using_core_count" -gt 0 ]] && printf "$format_i_data_param" "$compute_key.calibration.cores.using" "$using_core_count"
    [[ "$reported_core_count" != "$detected_core_count" ]] && printf "$format_s_data_param" "$compute_key.calibration.cores.discrepancy" "present"

    for mode_key (${(@k)cpu_modes}) printf "$format_i_data_param" "$compute_key.calibration.cpu.${mode_key:l}" "${cpu_modes[$mode_key]}"

    printf "$format_i_data_param" "$compute_key.calibration.iterations" "$iterations"

  } >> "$component_data_file"

  local -F4 events_per_second=0 events_per_processor_second=0 min_eps_score=9999999999 max_eps_score=0 variation_score=0 variation_percent=0 total_time=0 total_processor_execution_time=0
  local -i total_events=0 total_tests=0
  # See 14.3 (Parameter Expansion), i.e. '$', of  https://zsh.sourceforge.io/Doc/Release/Expansion.html#Expansio
  # Get Reference Baseline
  for ((i=1; i<=iterations; i++)) {

    (( total_tests++ ))
    # Always run calibration tests to establish baseline
    local baseline_run_report="${components_path}/cpu-reference-$i.log"

    if [[ "$force_regenerate_cpu_tests" == "true" || ! -f "$baseline_run_report" ]]; then
      sysbench --threads=1 --time="$iteration_time_limit" --forced-shutdown=1 --validate="on" cpu run > "$baseline_run_report"
      [[ "$generate_runtime_info_logs" == "true" ]] && printf "| %-37.37s %78s\n" "Calibrating CPU Reference Test:" "file://$baseline_run_report"
    else
      [[ "$generate_runtime_info_logs" == "true" ]] && printf "| %-57.57s %58.58s |\n" "Calibrating CPU Reference Test $i" "Re-Using existing CPU Reference Log."
    fi

    local -F2 baseline_total_eps=$(grep "events per second:" "$baseline_run_report" | awk '{print $4}')
    local -i baseline_total_events=$(grep "total number of events:" "$baseline_run_report" | awk '{print $5}')

    [[ "$baseline_total_eps" -gt "$max_eps_score" ]] && max_eps_score=$baseline_total_eps
    [[ "$baseline_total_eps" -lt "$min_eps_score" ]] && min_eps_score=$baseline_total_eps
    ((( total_events += baseline_total_events )))

    local baseline_total_time_string=$(grep "total time:" "$baseline_run_report" | awk '{print $3}')
    local baseline_thread_events_per_second_string=$(grep "events (avg/stddev):" "$baseline_run_report" | awk '{print $3}')
    local baseline_thread_execution_time_string=$(grep "execution time (avg/stddev):" "$baseline_run_report" | awk '{print $4}')

    local -F4 baseline_total_time="${baseline_total_time_string%s*}"
    local -F4 baseline_standard_ept="${baseline_thread_events_per_second_string%/*}"
    local -F2 baseline_deviation_ept="${baseline_thread_events_per_second_string#*/}"

    local -F4 baseline_thread_standard_execution_time="${baseline_thread_execution_time_string%/*}"
    local -F4 baseline_thread_deviation_execution_time="${baseline_thread_execution_time_string#*/}"

    (( total_time += baseline_total_time ))
    (( total_processor_execution_time += baseline_thread_standard_execution_time ))

    {
      printf "$format_f_data_param"   "$compute_key.calibrate.i$i.baseline.eps.total"               "$baseline_total_eps"
      printf "$format_f4_data_param"  "$compute_key.calibrate.i$i.baseline.events.thread.standard"  "$baseline_standard_ept"
      printf "$format_f4_data_param"  "$compute_key.calibrate.i$i.baseline.events.thread.deviation" "$baseline_deviation_ept"
      printf "$format_i_data_param"   "$compute_key.calibrate.i$i.baseline.events.total"            "$baseline_total_events"
      printf "$format_f4_data_param"  "$compute_key.calibrate.i$i.baseline.time.total"              "$baseline_total_time"
      printf "$format_f4_data_param"  "$compute_key.calibrate.i$i.baseline.time.thread.standard"    "$baseline_thread_standard_execution_time"
      printf "$format_f4_data_param"  "$compute_key.calibrate.i$i.baseline.time.thread.deviation"   "$baseline_thread_deviation_execution_time"
    } >> "$component_data_file"
  }

  (( total_processor_execution_time /= total_tests ))
  (( total_time /= total_tests ))
  (( total_events /= total_tests ))
  (( events_per_second = total_events / total_time ))
  (( events_per_processor_second = total_events / total_processor_execution_time ))
  (( variation_score = max_eps_score - min_eps_score ))
  (( variation_percent = variation_score / events_per_second * 100 ))
  (( loading_efficiency = total_processor_execution_time / total_time ))

  {
    printf "$format_f4_data_param"    "$compute_key.calibrate.time.cpu" "$total_processor_execution_time"
    printf "$format_f4_data_param"    "$compute_key.calibrate.time.wall" "$total_time"
    printf "$format_i_data_param"     "$compute_key.calibrate.events" "$total_events"
    printf "$format_f4_data_param"    "$compute_key.calibrate.eps.wall" "$events_per_second"
    printf "$format_f4_data_param"    "$compute_key.calibrate.eps.cpu" "$events_per_processor_second"
    printf "$format_f4_data_param"    "$compute_key.calibrate.eps.max.wall" "$max_eps_score"
    printf "$format_f4_data_param"    "$compute_key.calibrate.eps.min.wall" "$min_eps_score"
    printf "$format_f4_data_param"    "$compute_key.calibrate.eps.var.wall" "$variation_score"
    printf "$format_f4_data_param"    "$compute_key.calibrate.eps.var.percent" "$variation_percent"
    printf "$format_f4_data_param"    "$compute_key.calibrate.efficiency.cpu.schedule" "$loading_efficiency"
  } >> "$component_data_file"

}


# Run CPU Tests
