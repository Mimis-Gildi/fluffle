### Save Configuration Data: persist_test_configuration_data()
#
# Persist configuration data about the test setup and run to a property file.
#
# This function is used to store certain parameters about the test run so
# that they can be easily accessed later. The data is written to a file
# in the format of a shell script, with each parameter written as a
# variable assignment. The property file format can be used by other tools.
#
# The persisted data includes the version of the application running the
# test, the machine and host name of the agent, the OS and kernel version,
# the uptime of the OS, a flag indicating whether the test was run on
# Linux or MacOS, a flag indicating whether runtime debug information
# should be generated, the root and working directories of the test run,
# the path to the results file and the path to the components directory.
#
# - The function takes no arguments.
# - The function writes to the $component_data_file.
#
## Component Data File: $component_data_file
#
# The file in designed to be appended to by other functions.
# For that reason the properties are divided by namespace.
#
## Namespaces:
#
# - 'test':                           Test Configuration Data, i.e., test.mode=<something>.
# - 'app':                            Application Configuration Data, i.e., app.name=<something>:
#    - app.name:                          Name of the benchmark application;
#    - app.version:                       Version of the benchmark application.
# - 'agent':                          Agent Configuration Data, i.e., agent.machine=<something>:
#    - agent.machine:                     Detailed machine/OS build information;
#    - agent.host.name:                   The fully resolved hostname;
#    - agent.host.key:                    A simplified host key (short hostname);
#    - agent.os.issue:                    The operating system release (e.g. "macOS-15.3" or Debian issue);
#    - agent.os.kernel:                   The kernel version;
#    - agent.os.uptime:                   The system uptime.
# - 'flag':                           Behavior switching flags loaded or created; i.e., flag.<scope>.<group>, etc.
# - 'flag.runtime':                   Behavior flags set during runtime:
#    - flag.runtime.bench.io:             Whether IO benchmarks were executed (passed as an argument or loaded);
#    - flag.runtime.bench.cpu:            Whether CPU benchmarks were executed (passed as an argument or loaded);
#    - flag.runtime.linux:                Flag indicating 'running on a Linux' machine (by introspection);
#    - flag.runtime.macos:                Flag indicating if running on a macOS (expecting development machine);
#    - flag.runtime.debug:                Whether debug logging is enabled (not managed outside of script);
#    - flag.runtime.dry-run:              Whether the run is a dry-run (passed as an argument);
#    - flag.runtime.generate.io:          Force regeneration of IO test files;
#    - flag.runtime.generate.cpu:         Force regeneration of CPU tests;
#    - flag.runtime.generate.mem:         Force regeneration of Memory tests.
# - 'runtime':                        Runtime instance state, only relevant at runtime, i.e., runtime.tick=<something>:
#    - runtime.tick:                      Timestamp of the benchmark run.
# - 'runtime.fs':                     Runtime filesystem state, only relevant at runtime, i.e., runtime.fs.<something>:
#    - runtime.fs.root:                   The root directory for runtime resources;
#    - runtime.fs.work:                   The working directory for the benchmark;
#    - runtime.fs.data.test:              Directory for test-specific data;
#    - runtime.fs.data.root:              Directory where benchmark results are stored;
#    - runtime.fs.data.components:        Directory for individual benchmark component results and logs;
#    - runtime.fs.data.properties:        Full path to the generated properties file.
#    - runtime.fs.data.summary:           Full path to the summary data file.
# - 'runtime.mem':                    Runtime memory state, only relevant at runtime, i.e., runtime.mem.<something>:
#    - runtime.mem.size:                  Total physical memory (in GB);
#    - runtime.mem.free:                  Free physical memory (in GB).
# - 'runtime.swap':                   Runtime swap state, only relevant at runtime, i.e., runtime.swap.<something>:
#    - runtime.swap.size:                 Total swap space (in GB), (can be zero);
#    - runtime.swap.free:                 Free swap space (in GB), (can be zero).
# - 'runtime.cpu':                    Runtime CPU state, only relevant at runtime, i.e., runtime.cpu.<something>:
#    - runtime.cpu.core.count:            Number of physical CPU cores;
#    - runtime.cpu.hyper.count:           Number of hyper-threaded processing elements (PEs);
#    - runtime.cpu.load.count:            CPU load test multiplier/count (more than one process per PE).
# - 'param.test.io':                  Configured, durable test parameters consistently used test to test for IO performance comparison, i.e., param.test.io.<something>:
#    - param.test.io.file.count:          Number of files to use in IO tests (based on agents' actual build history);
#    - param.test.io.queue.count:         Number of queues for IO testing (based on historic runner behavior);
#    - param.test.io.ratio:               The read/write ratio for IO tests (based on historic runner behavior);
#    - param.test.io.size:                The data size used in IO tests (based on historic runner cache size changes).
#
## v1.0.0
persist_test_configuration_data() {
  {
    print "app.name=$bench_application_name"
    print "app.version=$bench_application_version"

    print "agent.machine=$agent_machine"
    print "agent.host.name=$bench_agent_host_name"
    print "agent.host.key=$bench_agent_host_key"
    print "agent.os.issue=$test_os_issue"
    print "agent.os.kernel=$test_os_kernel"
    print "agent.os.uptime=$test_os_uptime"

    print "runtime.tick=$bench_run_tick"

    printf $format_s_data_param "flag.runtime.bench.io"           "$exec_fio_bench"
    printf $format_s_data_param "flag.runtime.bench.cpu"          "$exec_cpu_bench"
    printf $format_s_data_param "flag.runtime.linux"              "$is_linux_agent"
    printf $format_s_data_param "flag.runtime.macos"              "$is_macos_local"
    printf $format_s_data_param "flag.runtime.debug"              "$generate_runtime_info_logs"
    printf $format_s_data_param "flag.runtime.dry-run"            "$dry_run"
    printf $format_s_data_param "flag.runtime.generate.io"        "$force_regenerate_fio_test_files"
    printf $format_s_data_param "flag.runtime.generate.cpu"       "$force_regenerate_cpu_tests"
    printf $format_s_data_param "flag.runtime.generate.mem"       "$force_regenerate_mem_tests"

    printf $format_s_data_param "runtime.fs.root"                 "$run_root_resource"
    printf $format_s_data_param "runtime.fs.work"                 "$run_work_resource"
    printf $format_s_data_param "runtime.fs.data.test"            "$run_test_resource"
    printf $format_s_data_param "runtime.fs.data.root"            "$run_bench_results_path"
    printf $format_s_data_param "runtime.fs.data.components"      "$run_bench_results_components_path"
    printf $format_s_data_param "runtime.fs.data.properties"      "$component_data_file"
    printf $format_s_data_param "runtime.fs.data.summary"         "$run_bench_summary_file"
    printf $format_f_data_param "runtime.mem.size"                "$test_mem_size"
    printf $format_f_data_param "runtime.mem.free"                "$test_mem_free"
    printf $format_f_data_param "runtime.swap.size"               "$test_swap_size"
    printf $format_f_data_param "runtime.swap.free"               "$test_swap_free"
    printf $format_i_data_param "runtime.cpu.core.count"          "$test_core_count"
    printf $format_i_data_param "runtime.cpu.hyper.count"         "$test_core_hyper_count"
    printf $format_i_data_param "runtime.cpu.load.count"          "$test_core_load_count"

    printf $format_i_data_param "param.$data_key.file.count"      "$test_file_count"
    printf $format_i_data_param "param.$data_key.queue.count"     "$test_queue_count"
    printf $format_f_data_param "param.$data_key.ratio"           "$test_rw_ratio"
    printf $format_s_data_param "param.$data_key.size"            "$test_io_size"

  } >> "$component_data_file"
}

### Run Selected Performance Tests in Order: File I/O, CPU, Memory; run_selected_tests
#
# Runs all of the selected tests, which are controlled by the `exec_fio_bench`,
# `exec_cpu_bench`, and `exec_mem_bench` variables.
#
# The tests that are run are:
#   - If `exec_fio_bench` is true, then the file I/O tests are run via a call to
#     `run_file_io_tests`.
#   - If `exec_cpu_bench` is true, then the CPU tests are run via a call to
#     `run_cpu_tests`.
#   - If `exec_mem_bench` is true, then the memory tests are run via a call to
#     `run_memory_tests`.
## Sets: nothing.
#
## Data Writen: none.
# This function is called by the `main` function.
#
## v1.0.0
run_selected_tests() {
  $exec_fio_bench && run_file_io_tests
  $exec_cpu_bench && run_cpu_tests
  $exec_mem_bench && run_memory_tests
}

