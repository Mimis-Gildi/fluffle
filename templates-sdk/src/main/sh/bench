#
# Prepare runtime resources before running the benchmark tests.
#
## Scopes are:
# - `run`: concrete runtime resources utilized by the benchmark tests;
# - `prod`: template runtime resources used by the production agent;
# - `dev`: project-concrete runtime resources used by the developer.
#
## Standard Component Resource Locations:
# - `root`:
#   - `production` root_resource_path is ALWAYS set to `/`;
#   - `dev` root_resource_path is ALWAYS set to Project-Node-Root:
#     i.e., `$HOME/IdeaProjects/Gervi-Hera-Vitr/fluffle/templates-sdk`;
#   - `dry-run` mode: root_resource_path is ALWAYS set to `$(mktemp -d)`.
#
## URI Conventions:
#  [ Concept with examples for each scope: `dry-run` (i.e., `run`) OR `prod` OR `dev` ]
#  - <root-resource>: [default `/`] =>
#    - `$(mktemp -d); OR
#    - `/`; OR
#    - `$HOME/IdeaProjects/Gervi-Hera-Vitr/fluffle/templates-sdk`;
#  - <work-resource>: [default `var/actions`] =>
#    - `$(mktemp -d)/var/actions`; OR
#    - `/var/actions`; OR
#    - `$HOME/IdeaProjects/Gervi-Hera-Vitr/fluffle/templates-sdk/src/main/resources`;
#  - <test-resource>: [default `runner-tests`] =>
#    - `$(mktemp -d)/var/actions/runner-tests`;OR
#    - `/var/actions/runner-tests`; OR
#    - `$HOME/IdeaProjects/Gervi-Hera-Vitr/fluffle/templates-sdk/src/test/resources/runner-tests`;
#  - <bench-results>: [default `bench-results`] =>
#    - `$(mktemp -d)/bench-results`; OR
#    - `$HOME/bench-results`; OR
#    - `$HOME/IdeaProjects/Gervi-Hera-Vitr/fluffle/templates-sdk/src/test/resources/bench-results`;
#  - <bench-components>: [default `components`] =>
#    - `$(mktemp -d)/bench-results/components`; OR
#    - `$HOME/bench-results/components`; OR
#    - `$HOME/IdeaProjects/Gervi-Hera-Vitr/fluffle/templates-sdk/src/test/resources/bench-results/components`;
#  - <summary-file>: [default `<agent-host-name>-bench-summary.log`] =>
#    - `$(mktemp -d)/<agent-host-name>-bench-summary.log`; OR
#    - `$HOME/<agent-host-name>-bench-summary.log`; OR
#    - `$HOME/IdeaProjects/Gervi-Hera-Vitr/fluffle/templates-sdk/src/test/resources/<agent-host-name>-bench-summary.log`;
#
## Scope activation logic:
# - `run`:
#   - is always active;
#   - mounted to tmp;
#   - used as is in `dry-run` mode;
#   - can run on non-compliant hosts;
# - `prod`:
#   - is active If-And-Only-If: `is_linux_agent` NOT in `dry-run` mode;
#   - remounted to prod persistent mounts by `prepare_resources()`;
#   - can only run on compliant production agent hosts;
#   - validated by `validate_production_resources()`;
#   - is persisted;
# - `dev`:
#   - is active If-And-Only-If: `is_macos_local` NOT in `dry-run` mode;
#   - remounted to dev persistent mounts by `prepare_resources()`;
#   - can only run on compliant development hosts;
#   - validated by `validate_development_resources()`;
#   - is retained in the project for developer's convenience.
#
# Sets: Key Global Resource Variables ALWAYS used:
# - `run_root_resource`:  ALWAYS TMP:       Concrete runtime resources utilized by the benchmark tests;
# - `run_work_resource`:                    All data generation is bellow this directory;
#      dry run:           TMP;
#      prod (Linux):      /var/actions;                                                     Rewritten in `prepare_resources()`;
#      dev (MacOS):       {proj}/src/test/resources;                                        Rewritten in `prepare_resources()`;
# - `run_test_resource`:                    All GENERATED test resources are bellow this directory;
#      dry run:           TMP;
#      prod (Linux):      /var/actions/runner-tests;                                        Rewritten in `prepare_resources()`;
#      dev (MacOS):       TMP;              NOT persisted, unlike prod, and different dir each run;
# - `run_bench_results_path`:               All benchmark results are stored bellow this directory;
#      dry run:           TMP;
#      prod (Linux):      {home}/bench-results;                                             Rewritten in `prepare_resources()`;
#      dev (MacOS):       {proj}/src/test/resources/bench-results;                          Rewritten in `prepare_resources()`;
# - `run_bench_results_components_path`:    All benchmark component results are stored bellow this directory;
#      dry run:           TMP;
#      prod (Linux):      {home}/bench-results/components;                                  Rewritten in `prepare_resources()`;
#      dev (MacOS):       {proj}/src/test/resources/bench-results/components;               Rewritten in `prepare_resources()`;
# - `run_bench_summary_file`:               Benchmark final results are written to this file;
#      dry run:           TMP/<agent-host-name>-bench-summary.log;
#      prod (Linux):      {home}/<agent-host-name>-bench-summary.log;                       Rewritten in `prepare_resources()`;
#      dev (MacOS):       {proj}/src/test/resources/<agent-host-name>-bench-summary.log;    Rewritten in `prepare_resources()`;
#
## v1.0.0
prepare_runtime_resources() {
  run_root_resource="${dry_run_root_resource_path}"
  run_work_resource="${run_root_resource}/${agent_work_resource}"
  run_test_resource="${run_work_resource}/${agent_test_resource}"
  run_bench_results_path="${run_root_resource}/${bench_results_resource}"
  run_bench_results_components_path="${run_bench_results_path}/${bench_results_components_resource}"
  run_bench_summary_file="${run_bench_results_path}/${bench_summary_file_name}"

  # `tmp` is always active and must exist on initiation regardless of outcomes
  if [[ ! -d "${run_root_resource}" ]]; then
    print "ERROR: Directory ${run_root_resource} does not exist. Exiting."
    exit 2
  fi

  mkdir -p "${run_test_resource}" || { print "ERROR: Failed to create work directory ${run_test_resource}."; exit 3; }
  mkdir -p "${run_bench_results_components_path}" || { print "ERROR: Failed to create results directory ${run_bench_results_components_path}."; exit 3; }
  touch "${run_bench_summary_file}" || { print "ERROR: Failed to create summary file ${run_bench_summary_file}."; exit 3; }

  typeset -rx run_root_resource  # this directory is always locked down through the tests
}

