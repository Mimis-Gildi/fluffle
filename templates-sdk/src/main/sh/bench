### Main Script Logic: main
#
# This is the main entry point for the script. It is the central controller of
# the script's logic flow. The main function is responsible for calling the
# functions that set up the benchmark job, prepare all of the resources needed
# for all of the tests, capturing all of the parameters and resources used by
# the tests, writing them to a properties file, printing a summary of the
# configuration, running all of the selected tests, and printing the results.
#
## Holds logical control flow and structure of the script.
#
# The main function is called by the shell when the script is invoked.
#
# - Requires no parameters;
# - Passes all parameters to the `parse_options` function;
# - Calls setup functions in sequential order;
# - Delegates testing to the `run_selected_tests` function.
#
## Sets: nothing.
#
## Data Writen: none.
#
## v1.0.0
main() {
  #  Setup Benchmark Job Environment
  print_header                                                                                      # Print application welcome header
  parse_options "$@"                                                                                # Parse script invocation options and set flags
  detect_os                                                                                         # Detect operating system running on
  check_root                                                                                        # On Linux exits if not root
  print_flags                                                                                       # Prints invocation flags understood
  output_width_warning                                                                              # Print warning if data doesn't fit in page_width

  #  Setup Selected Performance Tests
  prepare_resources                                                                                 # Prepare folders in use for tests for all supported operating systems
  setup_test_parameters                                                                             # Captures hardware and benchmark parameters for later use
  persist_test_configuration_data                                                                   # Write configuration data to a property file (later enhancements)
  log_system_bench_summary_header_info                                                              # Writes header info to summary file and console indicating 'configured' state
  print_filesystem_resources_used                                                                   # Print file system resources used by the benchmark tests script

  #  Run Selected Performance Tests
  run_selected_tests                                                                                # Run selected performance tests
}


### === Script Execution ===
main "$@"

exit 0

