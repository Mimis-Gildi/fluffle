  if [[ "$can_use_minimum_width" == true ]]; then
    io_data_row_format_key="minimum"
  elif [[ "$can_use_suggested_width" == true ]]; then
    io_data_row_format_key="suggested"
  elif [[ "$can_use_desired_width" == true ]]; then
    io_data_row_format_key="desired"
  fi
}

