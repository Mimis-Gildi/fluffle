#
## v1.0.0
prepare_resources() {

  prepare_runtime_resources
  component_data_file="${HOME}/${bench_agent_host_key}-bench-data.properties"

  if [[ "$dry_run" == true ]]; then
    printf "%s\n" "test.mode=dry-run" > "${component_data_file}"

    print "IMPORTANT: This is a dry-run benchmark test meant to investigate compatibility issues only." | tee "${run_bench_summary_file}"
    typeset -rx run_work_resource run_test_resource run_bench_results_path run_bench_results_components_path run_bench_summary_file

  elif [[ "$is_linux_agent" == true ]]; then
    printf "%s\n" "test.mode=production" > "${component_data_file}"

    #Important: $run_root_resource IS NOT changed, it is now the temp dir
    run_work_resource="${prod_agent_work_mount}"                                                    # On production agents /var/actions is mounted to a dedicated volume
    run_test_resource="${prod_agent_test_resource_path}"                                            # On production agents /var/actions/runner-tests may need to be created
    run_bench_results_path="${prod_bench_results_path}"                                             # On production agents ${HOME}/bench-results may need to be created
    run_bench_results_components_path="${prod_bench_results_components_path}"                       # On production agents ${HOME}/bench-results/components may need to be created
    run_bench_summary_file="${prod_bench_summary_file}"                                             # On production agents ${HOME}/${agent_host_name}-bench-summary.log is re-created
    typeset -rx run_work_resource run_test_resource run_bench_results_path run_bench_results_components_path run_bench_summary_file

    if [[ ! -d "${run_work_resource}" ]]; then
      print "ERROR: Directory ${run_work_resource} does not exist. Exiting."
      print "Observation: ${agent_work_resource} is mounted to ${prod_agent_work_mount}"
      print "Information: in production environment, ${agent_work_resource} is a dedicated large volume mount and must exist!"
      exit 2
    fi

    if [[ ! -d "${run_test_resource}" ]]; then
      mkdir -p "${run_test_resource}"
      chown -R "lugaru":"github" "${run_test_resource}"
    fi

    [[ ! -d "${run_bench_results_components_path}" ]] && mkdir -p "${run_bench_results_components_path}"
    [[ ! -d "${run_bench_results_path}" ]] && mkdir -p "${run_bench_results_components_path}"

    printf "%s: (%s) at %s.\n" "Production Bench Summary" "$bench_agent_host_name" "$(date)" | tee "${run_bench_summary_file}"

  elif [[ "$is_macos_local" == true ]]; then
    component_data_file="${dev_test_resource_path}/bench-data.properties"
    printf "%s\n" "test.mode=unit" > "${component_data_file}"

    #Important: run_root_resource IS NOT changed, it is now the temp dir
    run_work_resource="${dev_test_resource_path}"                                                   # Must exist: The School of Mimir local development environment is standardized
    run_bench_results_path="${dev_bench_results_path}"                                              # Can be created if missing
    run_bench_results_components_path="${dev_bench_results_components_path}"                        # Can be created if missing
    run_bench_summary_file="${dev_bench_summary_file}"                                              # Can be created if missing
    typeset -rx run_work_resource run_test_resource run_bench_results_path run_bench_results_components_path run_bench_summary_file

    if [[ ! -d "${run_work_resource}" ]]; then
      print "ERROR: Directory ${run_work_resource} does not exist. Exiting."
      print "Observation: ${dev_test_resource_path} is a standard project location that will exist on a correctly cloned project."
      exit 2
    fi

    [[ ! -d "${run_test_resource}" ]] && mkdir -p "${run_test_resource}"
    [[ ! -d "${run_bench_results_path}" ]] && mkdir -p "${run_bench_results_components_path}"

    printf "%s: (%s) at %s.\n" "Unit Test Bench Summary" "$bench_agent_host_name" "$(date)" | tee "${run_bench_summary_file}"
  else
    print "ERROR: Unknown OS or Agent Type. Exiting."
    exit 11
  fi

  typeset -rx component_data_file
}

### Sets the test parameters based on the current environment: setup_test_parameters()
#
# - `test_core_count` is determined by the number of available CPU cores.
# - `test_core_hyper_count` is `test_core_count` multiplied by 4 on macOS and 2 on Linux.
# - `test_core_load_count` is `test_core_count` multiplied by 4 on macOS and 16 on Linux.
# - `test_file_count` is 192 (64 * 3) in dry-run mode and 896 (128 * 7) in non-dry-run mode.
# - `test_queue_count` is 40 (32 + 8) in dry-run mode and 192 (128 + 64) in non-dry-run mode.
# - `test_io_size` is 512M in dry-run mode and 4G in non-dry-run mode.
#
## Sets:
# - test_os_kernel, test_os_uptime, test_os_issue;
# - test_io_size;
# - test_core_count, test_core_hyper_count, test_core_load_count, test_file_count, test_queue_count;
# - test_mem_size, test_mem_free, test_swap_size, test_swap_free.
#
## v1.0.0
setup_test_parameters(){

  local -r os_kernel="$(uname -o -r)"
  local -r os_uptime="$(uptime)"
  local -i core_count hyper_count load_count file_count queue_count
  local os_issue io_size
  local -F1 mem_size swap_size mem_free swap_free

  if [[ "$is_macos_local" == true ]]; then
    readonly core_count="$(sysctl -n hw.ncpu)"
    (( hyper_count = core_count * 4 ))
    (( load_count = core_count * 6 ))
    readonly hyper_count load_count

    readonly mem_size="$(sysctl -n hw.memsize | awk '{printf "%.2f", $1 / 1024 / 1024 / 1024}')"
    readonly swap_size="$(sysctl -n vm.swapusage | awk '{printf "%.2f", $3}')"
    readonly mem_free="$(vm_stat | awk '
      /Pages free/ {free=$3}
      /Pages inactive/ {inactive=$3}
      END {printf "%.2f", (free + inactive) * 4096 / 1024 / 1024 / 1024}
    ')"
    readonly swap_free="$(sysctl -n vm.swapusage | awk '{printf "%.2f", $3 - $4}')"

    readonly os_issue="$(sw_vers -productName)-$(sw_vers -productVersion)"
  elif [[ "$is_linux_agent" == true ]]; then
    readonly core_count="$(grep processor /proc/cpuinfo -c )"
    (( hyper_count = core_count * 2 ))
    (( load_count = core_count * 12 ))
    readonly hyper_count load_count

    readonly mem_size="$(awk '/MemTotal/ {printf "%.2f", $2 / 1024 / 1024}' /proc/meminfo)"
    readonly swap_size="$(awk '/SwapTotal/ {printf "%.2f", $2 / 1024 / 1024}' /proc/meminfo)"
    readonly mem_free="$(awk '/MemFree/ {printf "%.2f", $2 / 1024 / 1024}' /proc/meminfo)"
    readonly swap_free="$(awk '/SwapFree/ {printf "%.2f", $2 / 1024 / 1024}' /proc/meminfo)"

    readonly os_issue="$(cat /etc/issue)"
  else
    print "ERROR: Unknown OS or Agent Type Configuration. Exiting."
    exit 11
  fi

  if [[ "$dry_run" == true ]]; then
    (( file_count = 64 * 3 ))
    (( queue_count = 32 + 8 ))
    readonly io_size="512M"
    readonly file_count queue_count
  else
    (( file_count = 128 * 7 ))
    (( queue_count = 128 + 64 ))
    readonly io_size="4G"
    readonly file_count queue_count
  fi

    test_os_kernel="$os_kernel"
    test_os_uptime="$os_uptime"
    test_os_issue="$os_issue"
    test_io_size="$io_size"

    test_core_count=$core_count
    test_core_hyper_count=$hyper_count
    test_core_load_count=$load_count
    test_file_count=$file_count
    test_queue_count=$queue_count

    test_mem_size=$mem_size
    test_mem_free=$mem_free
    test_swap_size=$swap_size
    test_swap_free=$swap_free

  readonly test_os_kernel test_os_uptime test_os_issue
  readonly test_io_size
  readonly test_core_count test_core_hyper_count test_core_load_count test_file_count test_queue_count
  readonly test_mem_size test_mem_free test_swap_size test_swap_free
}

### Prints a header block of system information to the benchmark summary file: log_system_bench_summary_header_info()
#
# This includes:
#   - Date/Time
#   - Number of CPU Cores/Virtual/Hyper
#   - Memory/Swap (free/total)
#   - OS
#   - Kernel
#   - Uptime
#   - Full free output
#
## Sets: nothing.
#
## v1.0.0
log_system_bench_summary_header_info() {
  local -ri header_column_length=10
  (( data_column_length = page_width - 2 * margin_length - divider_length - header_column_length + 1 ))
  local -r fmt_rez_row="$divider %-${header_column_length}s: %${data_column_length}.${data_column_length}s $divider\n"

  local -r consolidated_cpu_cores_info="$test_core_count (HT: ${test_core_hyper_count} / Load: ${test_core_load_count})"
  local -r consolidated_mem_info="Format <free>/<total> => Mem=${test_mem_free}G/${test_mem_size}G; Swap=(${test_swap_free}G/${test_swap_size}G)"

  {
    print "$bar_h2"
    printf "$fmt_rez_row" "Date(Time)"  "$bench_run_tick"
    printf "$fmt_rez_row" "CPU C/H/V"   "$consolidated_cpu_cores_info"
    printf "$fmt_rez_row" "Mem; Swap"   "$consolidated_mem_info"
    printf "$fmt_rez_row" "OS"          "$test_os_issue"
    printf "$fmt_rez_row" "Kernel"      "$test_os_kernel"
    printf "$fmt_rez_row" "Uptime"      "$test_os_uptime"
  } | tee -a "${run_bench_summary_file}"
}


