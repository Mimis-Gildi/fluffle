### Detect the operating system and set appropriate flags: detect_os().
#
# This function checks the operating system via `uname` and `issue`.
#
## `uname` Linux
# -a, --all                     # print all information, in the following order, except omit -p and -i if unknown:
# -s, --kernel-name             # print the kernel name
# -n, --nodename                # print the network node hostname
# -r, --kernel-release          # print the kernel release
# -v, --kernel-version          # print the kernel version
# -m, --machine                 # print the machine hardware name
# -p, --processor               # print the processor type (non-portable)
# -i, --hardware-platform       # print the hardware platform (non-portable)
# -o, --operating-system        # print the operating system
# --help                        # display this help and exit
# --version                     # output version information and exit
#
## `uname` macOS
# -a                            # Behave as though the options -m, -n, -r, -s, and -v were specified.
# -m                            # Write the type of the current hardware platform to standard output.  (make(1) uses it to set the MACHINE variable.)
# -n                            # Write the name of the system to standard output.
# -o                            # This is a synonym for the -s option, for compatibility with other systems.
# -p                            # Write the type of the machine processor architecture to standard output.  (make(1) uses it to set the MACHINE_ARCH variable.)
# -r                            # Write the current release level of the operating system to standard output.
# -s                            # Write the name of the operating system implementation to standard output.
# -v                            # Write the version level of this release of the operating system to standard output.
# It sets one of two
# flags: `is_linux_agent` or `is_macos_local`. The `is_linux_agent` flag is
# set if the operating system is Debian GNU/Linux 12, which is the intended
# production environment. The `is_macos_local` flag is set if the operating
# system is macOS, which is the intended development environment. If the
# operating system is neither of these, the script will exit with an error
# message.
#
## Sets:
# - is_linux_agent=true when Linux OS is detected; else remains default false.
# - is_macos_local=true when macOS OS is detected; else remains default false.
# - agent_machine=(uname -v) by os_version local, else 'unsupported'.
#
## v1.0.0
detect_os() {
  local -r os_name=$(uname -s) os_version=$(uname -v)
  local -i text_width left_width right_width
  (( text_width = page_width - 6, left_width = text_width / 2, right_width = text_width - left_width ))
  readonly text_width left_width right_width

  case "${os_name}" in
    Linux)
      printf "$divider %-${left_width}s  %${right_width}s $divider\n" "Detected GNU/Linux" "production machine"
      typeset -rx is_linux_agent=true is_macos_local
      ;;
    Darwin)
      printf "$divider %-${left_width}s  %${right_width}s $divider\n" "Detected Mac OS X" "development machine"
      typeset -rx is_macos_local=true is_linux_agent
      ;;
    *)
      print "\n\n[ERROR]: Unsupported operating system: ${os_name}. Exiting.\n\n"
      exit 11
      ;;
  esac

  typeset -rx agent_machine="${os_version}"
}

### Show usage message: usage()
#
# This function prints the usage message for the script and exits with
# code 0. The usage message is as follows:
#
## Usage: $0 [--file-io]|[-f] [--cpu]|[-c] [--memory]|[-m] ([--all]|[-a]) <[--help]|[-h]> [--dry-run]|[-d]
#
## Options:
#   --file-io     Run File IO tests.
#   --cpu         Run CPU tests.
#   --memory      Run Memory tests.
#   --all         Run all tests (default if no options are provided).
#   --help        Show this help message and exit (also on unknown options).
#   --dry-run     No compliance checks + no persistence.
#
## Note: options do not combine: -fm is not the same as -f -m.
#
## Sets: nothing.
#
## v1.0.0
usage() {
  print "Usage: $0 [--file-io]|[-f] [--cpu]|[-c] [--memory]|[-m] ([--all]|[-a]) <[--help]|[-h]> [--dry-run]|[-d]"
  print
  print "Options:"
  print "  --file-io     Run File IO tests."
  print "  --cpu         Run CPU tests."
  print "  --memory      Run Memory tests."
  print "  --all         Run all tests (default if no options are provided)."
  print "  --help        Show this help message and exit (also on unknown options)."
  print "  --dry-run     No compliance checks + no persistence."
  print "Note: options do not combine: -fm is not the same as -f -m."
  exit 0
}

### Parse command-line arguments: parse_options()
#
# This function parses command-line options and sets the corresponding flags.
# It iterates over the command-line arguments and checks if any of the
# following options are present:
#
# - `--file-io` or `-f` to run File IO tests;
# - `--cpu` or `-c` to run CPU tests;
# - `--memory` or `-m` to run Memory tests;
# - `--all` or `-a` to run all tests (default if no options are provided);
# - `--help` or `-h` to show the help message and exit;
# - `--dry-run` or `-d` to run the script in dry-run mode (no compliance checks and no results are persisted).
#
## If any other option is provided, the script will print an error message and show the help message.
#
## If no flags are specified, the script will default to running all tests.
#
## Sets:
# - exec_fio_bench=true if the `--file-io` or `-f` option is provided; or no flags are provided.
# - exec_cpu_bench=true if the `--cpu` or `-c` option is provided; or no flags are provided.
# - exec_mem_bench=true if the `--memory` or `-m` option is provided; or no flags are provided.
# - dry_run=true if the `--dry-run` or `-d` option is provided.
#
## v1.0.0
parse_options() {

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --file-io | -f) exec_fio_bench=true ;;
      --cpu | -c) exec_cpu_bench=true ;;
      --memory | -m) exec_mem_bench=true ;;
      --all | -a) exec_fio_bench=true; exec_cpu_bench=true; exec_mem_bench=true ;;
      --help | -h) usage ;;
      --dry-run | -d) dry_run=true ;;
      *) print "ERROR: Unknown option $1"; usage ;;
    esac
    shift
  done

  # If no flags were specified, default to running all tests
  if [[ "$exec_fio_bench" == false && "$exec_cpu_bench" == false && "$exec_mem_bench" == false ]]; then
    typeset -rx exec_fio_bench=true exec_cpu_bench=true exec_mem_bench=true
  fi
}

