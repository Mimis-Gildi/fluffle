### Finalize File IO Transfer Modes: file_io_calculate_available_io_modes()
# Determine the file I/O modes that are available for the current OS
#
# - During dry runs, only sync is used
# - On macOS, only sync and mmap are used
# - On Linux, sync, async, and mmap are used
#
## Sets:
# - test_modes_io_channels_selected
#   - Linux: sync, async, mmap via `test_modes_io_channels`
#   - macOS: sync, mmap via `test_modes_io_channels_macosx`
#   - Dry Run: sync via `test_modes_io_channels_dry_run`
#
## Data Writen:
# - runtime.fs.data.transfer.modes
#
## v1.0.0
file_io_calculate_available_io_modes() {
  if [[ "$dry_run" == true ]]; then
    typeset -Arx test_modes_io_channels_selected=( "${(@kv)test_modes_io_channels_dry_run}" )       # Dry Run uses sync alone which is available on all platforms
  elif [[ "$is_macos_local" == true ]]; then
    typeset -Arx test_modes_io_channels_selected=( "${(@kv)test_modes_io_channels_macosx}" )        # macOS uses sync and mmap while kernel level async is not available
  elif [[ "$is_linux_agent" == true ]]; then
    typeset -Arx test_modes_io_channels_selected=( "${(@kv)test_modes_io_channels}" )               # Linux uses sync, async, and mmap
  else
    print "ERROR: Unsupported OS. Exiting."                                                         # This only happens if program flow broke
    typeset -Arx test_modes_io_channels_selected=()
  fi
  print "runtime.fs.data.transfer.modes='${(@k)test_modes_io_channels_selected}'" >> "$component_data_file"
}

