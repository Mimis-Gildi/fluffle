### Set IO Minimum Data Row Width: set_io_minimum_data_row_width()
#
# This function sets the minimum data row width for the IO report.
# It outputs a series of key-value pairs to a file specified by the global variable 'component_data_file'.
#
# The function uses several global formatting variables:
#   - 'format.io.data.row.key.minimum.length':        minimum required length to display just the Mode and Score columns;
#   - 'format.io.data.row.key.minimum.fits':          data fits into current page width.
#
## Sets:
#   - 'io_data_row_required_length_for_minimal_table':                        minimum required length to display just the Mode and Score columns;
#   - 'can_use_minimum_width':                        data fits into current page width.
#
## Data Writen:
#   - 'format.io.data.row.key.minimum.length':        <integer> - character count ;
#   - 'format.io.data.row.key.minimum.fits':          <boolean>.
#
## Generates: nothing.
#
## Prints: nothing.
#
## v1.0.0
set_io_minimum_data_row_width() {

  # Just the Mode and the Score Column followed by the filler column.
  local -i minimum_data_row_width=0
  # Titles on these 2 columns are longer than data so title length is used.
  (( minimum_data_row_width =  2 * margin_length + 2 * divider_length + io_col_grp_mode__width + io_column_group_width_score ))
  typeset -irx io_data_row_required_length_for_minimal_table=$minimum_data_row_width
  if [[ "$io_data_row_required_length_for_minimal_table" -le "$page_width" ]]; then
    can_use_minimum_width=true
  else
    print "ERROR: MINIMAL data does not fit into current page width. Exiting."
    exit 1
  fi

  {
    print "$format_io_data_row_key.minimum.length=$io_data_row_required_length_for_minimal_table"
    print "$format_io_data_row_key.minimum.fits=$can_use_minimum_width"
  } >> "$component_data_file"
}


### Set IO Suggested Data Row Width: set_io_suggested_data_row_width()
#
# This function sets the suggested data row width for the IO report.
# It outputs a series of key-value pairs to a file specified by the global variable 'component_data_file'.
#
# 1. Exit if didn't fit into minimal width;
# 2. Calculate the suggested data row width;
# 3. Check if suggested data row width fits into current page width;
# 3.a. Fits: disable minimum and don't set comment width expecting next fitting call;
# 3.b. Doesn't fit: set comment width and disable suggested.
#
# The function uses several global formatting variables:
#   - 'format.io.data.row.key.suggested.length':              suggested required length to display just the Mode, Score, Read, Write, and Latency columns;
#   - 'format.io.data.row.key.suggested.fits':                data fits into current page width.
#
## Sets:
#   - 'io_data_row_required_length_for_suggested_table':      suggested required length to display just the Mode, Score, Read, Write, and Latency columns;
#   - 'can_use_suggested_width':                              data fits into current page width.
#
## Data Writen:
#   - 'format.io.data.row.key.suggested.length':              <integer> - character count ;
#   - 'format.io.data.row.key.suggested.fits':                <boolean>.
#
## Generates: nothing.
#
## Prints: nothing.
set_io_suggested_data_row_width() {

  if [[ "$can_use_minimum_width" == false ]]; then
    print "ERROR: MINIMAL data row width assessment did not pass. SUGGESTED assessment is pointless. Exiting."
    exit 1
  fi

  # Mode, Score, Read, Write, Latency.
  local -i suggested_data_row_width=io_data_row_required_length_for_minimal_table                   # The width we already have for the Mode and Score columns (with margin for the comments) to which we will add the Read, Write, and Latency columns

  if [[ "$is_dry_run" == true ]]; then
    (( suggested_data_row_width += io_col_grp_width_by_os[dry] ))
  elif [[ "$is_macos_local" == true ]]; then
    (( suggested_data_row_width += io_col_grp_width_by_os[dev] ))
  elif [[ "$is_linux_agent" == true ]]; then
    (( suggested_data_row_width += io_col_grp_width_by_os[prd] ))
  else
    print "ERROR: Unknown Operating System. (OS needs to be discovered before setting suggested data row width) Exiting."
    exit 21
  fi
  (( suggested_data_row_width += divider_length ))
  typeset -irx io_data_row_required_length_for_suggested_table=$suggested_data_row_width

  if [[ "$io_data_row_required_length_for_suggested_table" -le "$page_width" ]]; then
    can_use_suggested_width=true
    typeset -rx can_use_minimum_width=false
  else
    typeset -rx can_use_suggested_width=false can_use_minimum_width=true can_use_desired_width=false
    (( io_data_row_comment_column_available_width = page_width - io_data_row_required_length_for_minimal_table ))
    typeset -irx io_data_row_comment_column_available_width
  fi

  {
    print "$format_io_data_row_key.suggested.length=$io_data_row_required_length_for_suggested_table"
    print "$format_io_data_row_key.suggested.fits=$can_use_suggested_width"
  } >> "$component_data_file"
}

### Set IO Desired Data Row Width: set_io_desired_data_row_width()
#
# This function sets the desired data row width for the IO report.
# It outputs a series of key-value pairs to a file specified by the global variable 'component_data_file'.
#
# 1. Exit if suggested width is not available;
# 2. Calculate the comment column width;
# 3. Check if the desired data row width leaves room for the comment column or 35;
# 3.a. Fits: disable suggested and set desired width;
# 3.b. Doesn't fit: enable suggested and don't set desired mode.
#
# The function uses several global formatting variables:
#   - 'format.io.data.row.key.desired.length':              desired required length to display all columns;
#   - 'format.io.data.row.key.desired.fits':                data fits into current page width;
#   - 'format.io.data.row.key.comment.width':               available width for the comment column;
#   - 'format.io.data.row.key.presentation-choice':         MIN, SUG, or DES based on the current data row width.
#
## Sets:
#   - 'io_data_row_required_length_for_desired_table':      desired required length to display all columns;
#   - 'can_use_desired_width':                              data fits into current page width.
#
## Data Writen:
#   - 'format.io.data.row.key.desired.length':              <integer> - character count ;
#   - 'format.io.data.row.key.desired.fits':                <boolean>;
#   - 'format.io.data.row.key.comment.width':               <integer> - character count;
#   - 'format.io.data.row.key.presentation-choice':         <string> - MIN, SUG, or DES.
#
## Generates: nothing.
#
## Prints: nothing.
set_io_desired_data_row_width() {

  if [[ "$can_use_suggested_width" == false ]]; then
    return 0
  fi

  typeset -irx io_data_row_comment_column_available_width=$(( page_width - io_data_row_required_length_for_suggested_table ))
  if [[ "$io_data_row_comment_column_available_width" -gt 34 ]]; then
    typeset -rx can_use_desired_width=true
    typeset -rx can_use_suggested_width=false
  else
    typeset -rx can_use_desired_width=false can_use_suggested_width=true
  fi

  {
    print "$format_io_data_row_key.desired.length=$io_data_row_required_length_for_suggested_table"
    print "$format_io_data_row_key.desired.fits=$can_use_desired_width"
    print "$format_io_data_row_key.comment.width=$io_data_row_comment_column_available_width"
    print "$format_io_data_row_key.presentation-choice='MIN=$can_use_minimum_width;SUG=$can_use_suggested_width;DES=$can_use_desired_width'"
  } >> "$component_data_file"

}

select_io_data_row_format() {
  persist_io_report_formatting_parameters
